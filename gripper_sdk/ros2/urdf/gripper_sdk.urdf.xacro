<?xml version="1.0"?>
<robot name="gripper_sdk" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <link name="gripper_base"/>
  <link name="gripper_tool"/>
  <joint name="gripper_fixed_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="gripper_tool"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>
</robot>
