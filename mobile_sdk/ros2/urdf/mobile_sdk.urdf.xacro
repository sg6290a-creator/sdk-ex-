<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mobile_sdk_robot">
  <xacro:arg name="use_mock_hardware" default="false"/>
  <xacro:arg name="port_front" default="/dev/ttyUSB0"/>
  <xacro:arg name="port_rear" default="/dev/ttyUSB1"/>
  <xacro:arg name="baudrate" default="19200"/>
  <xacro:arg name="front_driver_id" default="1"/>
  <xacro:arg name="rear_driver_id" default="2"/>
  <xacro:arg name="id_mdui" default="184"/>
  <xacro:arg name="id_mdt" default="183"/>
  <xacro:arg name="wheel_radius" default="0.098"/>
  <xacro:arg name="wheel_separation" default="0.32"/>
  <xacro:arg name="wheelbase" default="0.44"/>
  <xacro:arg name="gear_ratio" default="15"/>
  <xacro:arg name="poles" default="10"/>

  <xacro:property name="wheel_radius" value="$(arg wheel_radius)"/>
  <xacro:property name="wheel_separation" value="$(arg wheel_separation)"/>
  <xacro:property name="wheelbase" value="$(arg wheelbase)"/>
  <xacro:property name="wheel_width" value="0.04"/>

  <material name="blue"><color rgba="0.0 0.0 0.8 1.0"/></material>
  <material name="dark_gray"><color rgba="0.2 0.2 0.2 1.0"/></material>

  <xacro:macro name="wheel" params="prefix x_pos y_pos">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <inertia ixx="0.00052" ixy="0" ixz="0" iyy="0.00052" iyz="0" izz="0.00063"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${x_pos} ${y_pos} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>
  </xacro:macro>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${wheel_radius + 0.02}" rpy="0 0 0"/>
      <geometry><box size="${wheelbase * 0.8} ${wheel_separation * 0.7} 0.08"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${wheel_radius + 0.02}" rpy="0 0 0"/>
      <geometry><box size="${wheelbase * 0.8} ${wheel_separation * 0.7} 0.08"/></geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 ${wheel_radius + 0.02}" rpy="0 0 0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <xacro:wheel prefix="front_left" x_pos="${wheelbase/2}" y_pos="${wheel_separation/2 + wheel_width/2}"/>
  <xacro:wheel prefix="front_right" x_pos="${wheelbase/2}" y_pos="${-wheel_separation/2 - wheel_width/2}"/>
  <xacro:wheel prefix="rear_left" x_pos="${-wheelbase/2}" y_pos="${wheel_separation/2 + wheel_width/2}"/>
  <xacro:wheel prefix="rear_right" x_pos="${-wheelbase/2}" y_pos="${-wheel_separation/2 - wheel_width/2}"/>

  <xacro:include filename="$(find mobile_sdk)/urdf/ros2_control_mobile_sdk.urdf.xacro"/>
  <xacro:ros2_control_mobile_sdk
    use_mock_hardware="$(arg use_mock_hardware)"
    port_front="$(arg port_front)"
    port_rear="$(arg port_rear)"
    baudrate="$(arg baudrate)"
    front_driver_id="$(arg front_driver_id)"
    rear_driver_id="$(arg rear_driver_id)"
    id_mdui="$(arg id_mdui)"
    id_mdt="$(arg id_mdt)"
    wheel_radius="$(arg wheel_radius)"
    wheel_separation="$(arg wheel_separation)"
    wheelbase="$(arg wheelbase)"
    gear_ratio="$(arg gear_ratio)"
    poles="$(arg poles)"
  />
</robot>
